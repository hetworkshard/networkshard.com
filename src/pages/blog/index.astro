---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const pinned = posts.find(p => p.data.pinned);
const regularPosts = posts.filter(p => !p.data.pinned);

const postsByYear: Record<string, typeof regularPosts> = {};
for (const post of regularPosts) {
  const year = post.data.date.getFullYear().toString();
  if (!postsByYear[year]) postsByYear[year] = [];
  postsByYear[year].push(post);
}
const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="Blog" description="Writings on cybersecurity, penetration testing, and security research.">

  <!-- Pinned Post -->
  {pinned && (
    <section class="mb-10" aria-label="Pinned article">
      <a href={`/blog/${pinned.slug}`} class="pinned-changelog block group">
        <div class="flex items-center gap-2 mb-3.5">
          <span class="pinned-changelog-dot"></span>
          <span class="font-mono text-[11px] font-semibold uppercase tracking-widest text-primary">Pinned</span>
          <span class="flex-1 h-px bg-border/70"></span>
        </div>
        <h2 class="blog-card-title font-mono text-base font-semibold leading-snug text-foreground/90 motion-safe:transition-colors motion-safe:duration-150 group-hover:text-primary">{pinned.data.title}</h2>
      </a>
    </section>
  )}

  <!-- Blog Posts by Year -->
  <section aria-label="Latest articles">
    <div class="flex min-h-[calc(100vh-18rem)] flex-col gap-8 md:gap-10">
      {years.map(year => (
        <div class="flex flex-col md:flex-row md:gap-10">
          {/* Year label - mobile */}
          <div class="flex items-center gap-3 mb-1 md:hidden" aria-hidden="true">
            <span class="text-xs font-mono font-semibold text-muted-foreground uppercase tracking-wider shrink-0">{year}</span>
            <div class="flex-1 h-px bg-border/40"></div>
          </div>
          {/* Year label - desktop */}
          <div class="hidden md:flex w-14 shrink-0 flex-col items-end pt-[1.1rem]">
            <span class="text-xs font-mono font-semibold text-muted-foreground uppercase tracking-wider sticky top-24">{year}</span>
          </div>
          {/* Posts */}
          <div class="flex-1 md:border-t md:border-border/30 pt-1">
            <ul class="flex flex-col divide-y divide-border/20">
              {postsByYear[year].map(post => (
                <li>
                  <a href={`/blog/${post.slug}`} class="blog-card-link block w-full py-3 -mx-4 px-4 transition-colors duration-300 rounded">
                    <h3 class="blog-card-title font-mono text-sm font-semibold leading-snug text-foreground/90 transition-colors duration-150">
                      {post.data.title}
                    </h3>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </section>

{posts.length === 0 && (
    <div class="bento-card text-center py-12">
      <p class="text-muted-foreground">No posts yet. Check back soon!</p>
    </div>
  )}
</BaseLayout>
