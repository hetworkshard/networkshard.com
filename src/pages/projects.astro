---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    name: "VulnInsights",
    description: "Vulnerability insights and tracking dashboard for security assessments and penetration testing workflows.",
    tech: ["TypeScript", "CSS", "JavaScript"],
    github: "https://github.com/hetworkshard/vulninsights",
  },
  {
    name: "Cinemax",
    description: "Full-stack movie booking and management platform with user-facing frontend and admin panel.",
    tech: ["PHP", "JavaScript", "CSS", "HTML"],
    github: "https://github.com/hetworkshard/cinemax",
  },
  {
    name: "QuickMeds",
    description: "Quick medicine lookup and pharmacy management application.",
    tech: [],
    github: "https://github.com/hetworkshard/QuickMeds",
  },
  {
    name: "Table No 21",
    description: "Restaurant POS (Point of Sale) system for streamlined order management, billing, and table tracking.",
    tech: ["POS", "Restaurant Management", "Order System"],
    github: "",
  },
];

---

<BaseLayout title="Projects" description="Things I've built and worked on.">
  <!-- Projects -->
  <section class="pb-10 md:pb-12">
    <header class="mb-6">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground leading-tight mb-2">Projects</h1>
      <p class="text-base text-muted-foreground">Things I've built and worked on.</p>
    </header>

    <div class="flex flex-col gap-3">
      {projects.map(project => (
        <div class="bento-card">
          <div class="mb-2">
            <span class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground/60">/projects/{project.name.toLowerCase().replace(/\s+/g, '-')}</span>
            <h3 class="text-base font-semibold text-foreground mt-1">{project.name}</h3>
          </div>
          <p class="text-sm text-muted-foreground leading-relaxed mb-3">{project.description}</p>
          <div class="flex flex-wrap items-center justify-between gap-3">
            {project.tech.length > 0 && (
              <div class="flex flex-wrap items-center gap-1.5">
                <span class="text-[10px] font-mono font-semibold uppercase tracking-wider text-muted-foreground/60 mr-1">Technologies:</span>
                {project.tech.map(t => (
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-mono bg-muted/70 text-muted-foreground border border-border/60">{t}</span>
                ))}
              </div>
            )}
            {project.github && (
              <a href={project.github} target="_blank" rel="noopener" class="text-muted-foreground hover:text-foreground transition-colors shrink-0" aria-label={`${project.name} on GitHub`}>
                <svg class="size-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>
