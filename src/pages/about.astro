---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const postCount = posts.filter(p => !p.data.draft).length;

const skills = [
  'Penetration Testing', 'VAPT', 'Red Teaming', 'Vulnerability Assessment',
  'Security Research', 'Ethical Hacking', 'Burp Suite', 'Nmap', 'Metasploit',
  'Kali Linux', 'Wireshark', 'Python', 'Docker', 'Bash', 'Linux'
];
---

<BaseLayout title="About Het Patel — Cybersecurity Engineer" description="About Het Patel — Cybersecurity Engineer specializing in penetration testing, VAPT, vulnerability assessment, and security research at Inventyv.">
  <section class="pb-8 md:pb-12 space-y-6">
    <div class="bento-card about-profile-card">
      <div class="flex flex-col gap-5">
        <div class="flex items-start gap-4">
          <img
            src="/me.webp"
            alt="Het Patel — Cybersecurity Engineer"
            width="765"
            height="1024"
            class="w-20 h-20 md:w-28 md:h-28 rounded-xl object-cover object-[center_30%] shrink-0 ring-1 ring-border/50"
            loading="eager"
            decoding="async"
          />
          <div class="min-w-0">
            <h1 class="text-2xl md:text-4xl font-bold text-foreground">Het Patel</h1>
            <p class="text-sm text-muted-foreground mt-1">@hetworkshard</p>
            <p class="text-sm text-muted-foreground mt-1">India</p>
            <p class="text-sm text-muted-foreground">Inventyv Software Services Pvt. Ltd.</p>
          </div>
        </div>

        <div class="space-y-4">
          <p class="text-base text-muted-foreground leading-relaxed">
            I'm a Cybersecurity Engineer - Intern focused on building defensive systems that are practical, scalable, and testable. I work across penetration testing, vulnerability validation, and secure engineering practices.
          </p>
          <p class="text-base text-muted-foreground leading-relaxed">
            I specialize in Linux-first security workflows, web and infrastructure testing, and research-driven remediation while learning through hands-on delivery in real-world environments. My approach is simple: verify everything, automate what repeats, and keep systems understandable.
          </p>
        </div>

        <div>
          <p class="text-xs font-mono font-semibold uppercase tracking-wider text-muted-foreground mb-3">Skills & Tools</p>
          <div class="skills-strip">
            <div class="skills-track">
              {skills.concat(skills).map(skill => (
                <span class="inline-flex items-center gap-1.5 text-xs font-mono font-medium px-2.5 py-1 rounded-md border border-border/60 bg-muted/70 text-muted-foreground">
                  <svg class="size-3.5 text-primary/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
                  <span>{skill}</span>
                </span>
              ))}
            </div>
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-3">
          <a href="https://github.com/hetworkshard" target="_blank" rel="noopener" class="btn-neo-primary">GitHub</a>
          <a href="/Het Patel.pdf" download class="btn-neo-outline">
            Download CV
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Hall of Fame -->
  <section class="pb-8 md:pb-12">
    <h2 class="text-xs font-mono font-semibold text-muted-foreground uppercase tracking-wider mb-4">Hall of Fame</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <div class="bento-card">
        <p class="text-lg font-bold text-foreground">CERT-IN</p>
        <p class="text-sm text-muted-foreground mt-0.5">Indian Computer Emergency Response Team</p>
        <p class="text-sm text-muted-foreground mt-1">Hall of Fame — September & October 2025</p>
        <a href="https://www.cert-in.org.in/Hallof_Fame_Oct25.jsp" target="_blank" rel="noopener"
          class="inline-block mt-2 text-xs font-mono text-primary hover:text-primary-hover transition-colors">
          View on CERT-IN &rarr;
        </a>
      </div>
      <div class="bento-card">
        <p class="text-lg font-bold text-foreground">Zyte</p>
        <p class="text-sm text-muted-foreground mt-0.5">Responsible Disclosure Program</p>
        <p class="text-sm text-muted-foreground mt-1">Security Researcher — Hall of Fame</p>
        <a href="https://www.zyte.com/terms-policies/responsible-disclosure-policy/" target="_blank" rel="noopener"
          class="inline-block mt-2 text-xs font-mono text-primary hover:text-primary-hover transition-colors">
          View on Zyte &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- CVE -->
  <section class="pb-8 md:pb-12">
    <h2 class="text-xs font-mono font-semibold text-muted-foreground uppercase tracking-wider mb-4">CVE</h2>
    <div class="bento-card">
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
          <p class="text-lg font-bold text-foreground">Arbitrary API Token Creation</p>
          <p class="text-sm text-muted-foreground mt-0.5">InvenTree Security Advisory</p>
        </div>
        <span class="shrink-0 inline-flex items-center rounded-md border border-border/60 bg-muted/60 px-2.5 py-1 text-xs font-mono font-semibold text-foreground">
          8.3/10
        </span>
      </div>

      <div class="mt-4 space-y-2">
        <p class="text-xs font-mono font-semibold uppercase tracking-wider text-muted-foreground">Impact</p>
        <p class="text-sm text-muted-foreground leading-relaxed">
          Any authenticated InvenTree user can create a valid API token attributed to any other user in the system — including administrators and superusers — by supplying the target's user ID in the <span class="font-mono">user</span> field of a <span class="font-mono">POST /api/user/tokens/</span> request. The returned token is immediately usable for full API authentication as the target user, from any network location, with no further interaction required.
        </p>
      </div>

      <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div class="rounded-lg border border-border/60 bg-muted/40 p-3">
          <p class="text-xs font-mono font-semibold uppercase tracking-wider text-muted-foreground">CVE ID</p>
          <p class="mt-1 text-sm font-mono text-foreground">CVE-2026-35478</p>
        </div>
        <div class="rounded-lg border border-border/60 bg-muted/40 p-3">
          <p class="text-xs font-mono font-semibold uppercase tracking-wider text-muted-foreground">Score</p>
          <p class="mt-1 text-sm font-mono text-foreground">8.3/10</p>
        </div>
      </div>

      <a
        href="https://github.com/inventree/InvenTree/security/advisories/GHSA-qh5j-c28q-c4rg"
        target="_blank"
        rel="noopener"
        class="inline-block mt-4 text-xs font-mono text-primary hover:text-primary-hover transition-colors"
      >
        View advisory on GitHub &rarr;
      </a>
    </div>
  </section>

  <!-- Certifications -->
  <section class="pb-8 md:pb-12">
    <h2 class="text-xs font-mono font-semibold text-muted-foreground uppercase tracking-wider mb-4">Certifications</h2>
    <div class="bento-card">
      <div class="flex justify-between items-center">
        <div>
          <p class="text-base font-bold text-foreground">CRTA</p>
          <p class="text-sm text-muted-foreground">Certified Red Team Analyst</p>
        </div>
        <span class="text-sm font-mono text-muted-foreground">Cyberwarfare</span>
      </div>
    </div>
  </section>

  <!-- Site Stats -->
  <section class="pb-8 md:pb-12">
    <h2 class="text-xs font-mono font-semibold text-muted-foreground uppercase tracking-wider mb-4">Site Stats</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      <div class="bento-card">
        <span class="text-xs font-mono font-semibold uppercase tracking-wider text-muted-foreground">Total Views</span>
        <p class="mt-2 text-2xl font-bold text-foreground" id="stat-total-views">--</p>
      </div>
      <div class="bento-card">
        <span class="text-xs font-mono font-semibold uppercase tracking-wider text-muted-foreground">Blog Posts</span>
        <p class="mt-2 text-2xl font-bold text-foreground">{postCount}</p>
      </div>
      <div class="bento-card col-span-2 sm:col-span-1">
        <span class="text-xs font-mono font-semibold uppercase tracking-wider text-muted-foreground">Since</span>
        <p class="mt-2 text-2xl font-bold text-foreground">2025</p>
      </div>
    </div>
  </section>

  <!-- Connect -->
  <section class="pb-8 md:pb-12">
    <h2 class="text-xs font-mono font-semibold text-muted-foreground uppercase tracking-wider mb-4">Connect</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
      <a href="https://github.com/hetworkshard" target="_blank" rel="noopener" class="bento-card group block">
        <div class="flex items-center gap-2 mb-1">
          <svg class="size-4 text-muted-foreground" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          <span class="text-sm font-semibold text-foreground">GitHub</span>
        </div>
        <span class="text-xs font-mono text-muted-foreground group-hover:text-primary transition-colors">@hetworkshard</span>
      </a>

      <a href="https://www.linkedin.com/in/hetpatel9/" target="_blank" rel="noopener" class="bento-card group block">
        <div class="flex items-center gap-2 mb-1">
          <svg class="size-4 text-muted-foreground" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          <span class="text-sm font-semibold text-foreground">LinkedIn</span>
        </div>
        <span class="text-xs font-mono text-muted-foreground group-hover:text-primary transition-colors">hetpatel9</span>
      </a>

      <a href="https://tryhackme.com/p/hettt" target="_blank" rel="noopener" class="bento-card group block">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-xs font-bold font-mono text-muted-foreground">THM</span>
          <span class="text-sm font-semibold text-foreground">TryHackMe</span>
        </div>
        <span class="text-xs font-mono text-muted-foreground group-hover:text-primary transition-colors">@hettt &middot; Top 15%</span>
      </a>

      <a href="https://hettt.medium.com/" target="_blank" rel="noopener" class="bento-card group block">
        <div class="flex items-center gap-2 mb-1">
          <svg class="size-4 text-muted-foreground" viewBox="0 0 24 24" fill="currentColor"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
          <span class="text-sm font-semibold text-foreground">Medium</span>
        </div>
        <span class="text-xs font-mono text-muted-foreground group-hover:text-primary transition-colors">@hettt</span>
      </a>

      <a href="mailto:hello@networkshard.com" class="bento-card group block">
        <div class="flex items-center gap-2 mb-1">
          <svg class="size-4 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <span class="text-sm font-semibold text-foreground">Email</span>
        </div>
        <span class="text-xs font-mono text-muted-foreground group-hover:text-primary transition-colors">hello@networkshard.com</span>
      </a>
    </div>
  </section>
</BaseLayout>
